{
  "name": "bundler-comparison",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "build": "npm run build:rolldown && npm run build:rspack && npm run build:webpack && npm run build:esbuild && npm run build:rollup",
    "build:rolldown": "rolldown -c",
    "build:rspack": "rspack build",
    "build:webpack": "webpack",
    "build:esbuild": "node esbuild.config.mjs",
    "build:rollup": "rollup -c",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@rspack/cli": "latest",
    "@rspack/core": "latest",
    "esbuild": "latest",
    "rolldown": "https://pkg.pr.new/rolldown/rolldown@9574",
    "rollup": "latest",
    "webpack": "^5.107.2",
    "webpack-cli": "^7.0.2"
  }
}
